# Copy to .env and fill in values
# Estos defaults asumen Supabase self-hosted con el docker-compose oficial corriendo en localhost

NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Postgres (Supabase self-hosted, conexión DIRECTA — puerto 5433 vía override)
# El puerto 5432 está ocupado por Supavisor (pooler). Drizzle necesita conexión directa para DDL.
DATABASE_URL=postgres://postgres:your-super-secret-and-long-postgres-password@localhost:5433/postgres

# Supabase Auth (GoTrue) — DEBE coincidir con JWT_SECRET de Supabase
SUPABASE_JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
SUPABASE_URL=http://localhost:8000
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
